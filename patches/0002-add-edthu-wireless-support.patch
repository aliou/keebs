+    LPWR_WAKEUP_ONEKEY,
+    LPWR_WAKEUP_ENCODER,
+    LPWR_WAKEUP_SWITCH,
+} lpwr_wakeupcd_t;
+
+typedef enum {
+    LPWR_MODE_TIMEOUT = 0,
+} lpwr_mode_t;
+
+lpwr_state_t lpwr_get_state(void);
